# ─── Database ──────────────────────────────────────────────────────────────────
APP_DATA_SOURCE=supabase
APP_SQLITE_PATH=data/watchlab.db

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Выберите один из вариантов ниже и раскомментируйте.
# Без этих переменных коды печатаются в консоль (dev-режим).

# ── Яндекс Почта ──────────────────────────────────────────────────────────────
# 1. Включите «Пароли приложений» в настройках Яндекс ID
# 2. Создайте пароль приложения для «Почта»
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@yandex.ru
# SMTP_PASS=xxxxxxxxxxxx
# EMAIL_FROM=WatchLab <your@yandex.ru>

# ── Mail.ru ───────────────────────────────────────────────────────────────────
# 1. Включите доступ по паролю в настройках Mail.ru
# 2. Создайте «Пароль для внешних приложений»
SMTP_HOST= "smtp.mail.ru"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=zzhhl@mail.ru
SMTP_PASS=hW1g4D5KgqIFItcx76D3
EMAIL_FROM=WatchLab <zzhhl@mail.ru> 

# ── Gmail ─────────────────────────────────────────────────────────────────────
# 1. Включите двухфакторную аутентификацию в Google-аккаунте
# 2. Создайте «Пароль приложения» (App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxxxxxxxxxx
# EMAIL_FROM=WatchLab <your@gmail.com>

# ─── Session ───────────────────────────────────────────────────────────────────
# openssl rand -base64 48
APP_SESSION_SECRET=change-me-in-production
APP_SESSION_MAX_AGE_SECONDS=604800

# ─── Auth ──────────────────────────────────────────────────────────────────────
ENABLE_DEMO_AUTH=true
