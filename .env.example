# Источник данных для backend.
#   sqlite   — реальная локальная БД (файл), без внешних сервисов. Дефолт.
#   mock     — данные в памяти, теряются при рестарте.
#   supabase — внешний Supabase-проект.
APP_DATA_SOURCE=sqlite

# Путь до файла SQLite (используется при APP_DATA_SOURCE=sqlite).
# Можно указать абсолютный или относительный путь. Спец. значение ":memory:" — БД в RAM.
APP_SQLITE_PATH=data/watchlab.db

# Обязательно при APP_DATA_SOURCE=supabase.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Обязательно в production. Сгенерируйте длинное случайное значение.
APP_SESSION_SECRET=change-me-in-production
APP_SESSION_MAX_AGE_SECONDS=604800

# В production выставьте false, чтобы выключить быстрый вход по ролям.
ENABLE_DEMO_AUTH=true
