# Backend mode: "mock" works locally without external services, "supabase" uses Supabase tables.
APP_DATA_SOURCE=mock

# Required when APP_DATA_SOURCE=supabase.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required in production. Generate a long random value.
APP_SESSION_SECRET=change-me-in-production
APP_SESSION_MAX_AGE_SECONDS=604800

# Set to false in production if demo role switching should be disabled.
ENABLE_DEMO_AUTH=true
